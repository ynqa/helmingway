{
  "$schema": "./node_modules/oxlint/configuration_schema.json",

  // Keep oxlint focused on import ordering for now.
  "categories": {
    "correctness": "off",
    "nursery": "off",
    "pedantic": "off",
    "perf": "off",
    "restriction": "off",
    "style": "off",
    "suspicious": "off",
  },
  "rules": {
    "sort-imports": "error",
  },
}
