{
  "name": "helmingway",
  "displayName": "Helmingway",
  "version": "0.1.0",
  "description": "PoC Helm preview and diff from the editor title bar.",
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint src"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "helmingway.openReleasePreview",
        "title": "Open Preview"
      },
      {
        "command": "helmingway.compareSelectedReleases",
        "title": "Compare"
      },
      {
        "command": "helmingway.rebuildHelmTemplateCache",
        "title": "Rebuild Helm Template Cache",
        "icon": "$(refresh)"
      },
      {
        "command": "helmingway.closeAllPreviews",
        "title": "Close All Previews",
        "icon": "$(close-all)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "helmingway.openReleasePreview",
          "when": "false"
        },
        {
          "command": "helmingway.rebuildHelmTemplateCache",
          "when": "false"
        },
        {
          "command": "helmingway.compareSelectedReleases",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "helmingway.rebuildHelmTemplateCache",
          "when": "view == helmingway.preview",
          "group": "navigation"
        },
        {
          "command": "helmingway.closeAllPreviews",
          "when": "view == helmingway.preview",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "helmingway.openReleasePreview",
          "when": "view == helmingway.preview && viewItem == release"
        },
        {
          "command": "helmingway.compareSelectedReleases",
          "when": "view == helmingway.preview && viewItem == release && listMultiSelection"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "helmingway",
          "title": "Helmingway",
          "icon": "resources/helmingway.svg"
        }
      ]
    },
    "views": {
      "helmingway": [
        {
          "id": "helmingway.preview",
          "name": "Preview"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "packageManager": "pnpm@10.27.0"
}
