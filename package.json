{
  "name": "helmingway",
  "displayName": "Helmingway",
  "description": "PoC Helm preview and diff from the editor title bar.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:helmingway.previewFromEditor",
    "onCommand:helmingway.diffFromEditor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "helmingway.previewFromEditor",
        "title": "Helmingway: Preview"
      },
      {
        "command": "helmingway.diffFromEditor",
        "title": "Helmingway: Diff"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "helmingway.previewFromEditor",
          "group": "navigation@100",
          "when": "resourceScheme == file && editorLangId == yaml"
        },
        {
          "command": "helmingway.diffFromEditor",
          "group": "navigation@101",
          "when": "resourceScheme == file && editorLangId == yaml"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "check-types": "tsc --noEmit -p ./"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "typescript": "^6.0.2"
  }
}
