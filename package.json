{
  "name": "helmingway",
  "displayName": "Helmingway",
  "description": "PoC Helm preview and diff from the editor title bar.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "helmingway",
          "title": "Helmingway",
          "icon": "resources/helmingway.svg"
        }
      ]
    },
    "views": {
      "helmingway": [
        {
          "id": "helmingway.charts",
          "name": "Charts"
        },
        {
          "id": "helmingway.aliases",
          "name": "Aliases"
        },
        {
          "id": "helmingway.resources",
          "name": "Resources"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.27.0"
}
